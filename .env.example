# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (local or Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# ── Auth.js (NextAuth v5) ────────────────────────────────
# Generate with:  openssl rand -base64 32   OR   npx auth secret
AUTH_SECRET="replace-me-with-a-32-byte-secret"

# Production URL (omit for local dev)
# AUTH_URL="https://your-app.up.railway.app"

# ── Google OAuth ─────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

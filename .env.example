# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (local or Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# ── Auth.js (NextAuth v5) ────────────────────────────────
# Generate with:  openssl rand -base64 32   OR   npx auth secret
AUTH_SECRET="replace-me-with-a-32-byte-secret"

# Production URL (omit for local dev)
# AUTH_URL="https://your-app.up.railway.app"

# ── Google OAuth ─────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ───────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Webhook signing secret: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""

# Price IDs from Stripe products (https://dashboard.stripe.com/products)
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# ── Email (Resend) ───────────────────────────────────────
# Get your API key: https://resend.com/api-keys
RESEND_API_KEY=""
# From email (must be a verified domain in Resend)
FROM_EMAIL="onboarding@resend.dev"

# ── AI (OpenAI) ──────────────────────────────────────────
# Get your API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional: override the model (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o"

# ── File Uploads (UploadThing) ───────────────────────────
# Get your secret key: https://uploadthing.com/dashboard
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
